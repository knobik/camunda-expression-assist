{
  "name": "camunda-modeler-expression-assist",
  "version": "0.1.0",
  "description": "JUEL expression autocompletion and validation for Camunda Modeler (Camunda 7)",
  "main": "index.js",
  "scripts": {
    "build": "peggy --format es src/juel.peggy -o src/juelParser.js && webpack",
    "watch": "peggy --format es src/juel.peggy -o src/juelParser.js && webpack --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "camunda-modeler-plugin-helpers": "^6.0.0",
    "camunda-modeler-webpack-plugin": "^0.2.0",
    "peggy": "^5.1.0",
    "vitest": "^4.1.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.0"
  }
}
